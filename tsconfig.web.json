{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "lib": ["ES2018", "ES2022.Intl", "DOM", "DOM.Iterable"],
    "types": [],
    "skipLibCheck": true
  },
  "include": ["packages", "types/env.d.ts", "types/style.d.ts"],
  "exclude": [
    "node_modules",
    "**/dist",
    "**/__tests__/**/*",
    "**/buildfile.ts",
    "**/test-helper",
    "packages/test-utils",
    "**/*.md"
  ]
}
